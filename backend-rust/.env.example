# Environment variables for local development
# Copy this file to .env and fill in your values

# Server
Server__Host=0.0.0.0
Server__Port=10000

# MongoDB
MongoDB__Uri=mongodb://localhost:27017
MongoDB__Database=defi10

# Redis
Redis__Url=redis://localhost:6379
Redis__PoolSize=10
Redis__DefaultTtlSeconds=300

# RabbitMQ
RabbitMQ__Url=amqp://guest:guest@localhost:5672
RabbitMQ__PrefetchCount=10

# JWT
Jwt__Secret=your_secret_key_here_change_in_production
Jwt__ExpirationHours=24

# CORS
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:10002

# Rate Limiting
RateLimiting__Enabled=true
RateLimiting__MaxRequests=100
RateLimiting__WindowSeconds=60

# Blockchain RPC endpoints
Blockchain__AlchemyApiKey=your_alchemy_api_key_here

# Logging
RUST_LOG=info,defi10=debug
